---
import { initUstaticCss } from '../lib/ustaticCss'

// Инициализация ustatic-css с модулями по умолчанию
// При SSR эта функция возвращает HTML строку с <link> тегами
const stylesheets = await initUstaticCss()
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Astro Basics</title>
		
		<!-- Стили ustatic-css (сгенерированы при SSR) -->
		<slot name="head" set:html={stylesheets} />
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
